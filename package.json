{
  "name": "ai-assurance-control-plane",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@6.11.0",
  "scripts": {
    "dev:all": "pnpm --parallel --stream --filter @aiacp/api --filter @aiacp/web run dev",
    "dev:web": "pnpm --filter @aiacp/web dev",
    "dev:api": "pnpm --filter @aiacp/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "pnpm prisma:generate && tsx seed/seed.ts"
  },
  "dependencies": {
    "@aiacp/audit-engine": "workspace:*",
    "@aiacp/connectors-openclaw": "workspace:*",
    "@aiacp/core-domain": "workspace:*",
    "@aiacp/evidence-engine": "workspace:*",
    "@aiacp/policy-packs": "workspace:*",
    "@aiacp/rules-engine": "workspace:*",
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.14",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "yaml": "^2.7.1"
  }
}
